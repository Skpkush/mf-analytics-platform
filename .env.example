# ============================================
# Mutual Fund Analytics Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to git.

# --- Local PostgreSQL (primary post-Azure-trial) ---
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=mf_analytics
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=

# --- Azure SQL Database ---
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=mf_analytics
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=
AZURE_SQL_DRIVER={ODBC Driver 18 for SQL Server}

# --- Azure Blob Storage ---
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER_RAW=raw
AZURE_STORAGE_CONTAINER_PROCESSED=processed

# --- Azure Key Vault (optional, for prod) ---
AZURE_KEY_VAULT_NAME=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Data acquisition ---
YAHOO_FINANCE_TIMEOUT=30
AMFI_URL=https://www.amfiindia.com/spages/NAVAll.txt

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# --- Streamlit ---
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0
